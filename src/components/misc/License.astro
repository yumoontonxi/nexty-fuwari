---
import { Icon } from "astro-icon/components";
import { licenseConfig, profileConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";

interface Props {
	title: string;
	slug: string;
	pubDate: Date;
	class: string;
}

const { title, pubDate } = Astro.props;
const className = Astro.props.class;
const profileConf = profileConfig;
const licenseConf = licenseConfig;
const postUrl = decodeURIComponent(Astro.url.toString());
---
<div class={`license-block relative transition overflow-hidden py-5 px-6 ${className}`}>
    <div class="license-title transition font-bold text-[var(--text-primary)]">
        {title}
    </div>
    <a href={postUrl} class="link text-[var(--primary)]">
        {postUrl}
    </a>
    <div class="flex gap-6 mt-2">
        <div>
            <div class="transition text-[var(--text-tertiary)] text-sm">{i18n(I18nKey.author)}</div>
            <div class="transition text-[var(--text-secondary)] line-clamp-2">{profileConf.name}</div>
        </div>
        <div>
            <div class="transition text-[var(--text-tertiary)] text-sm">{i18n(I18nKey.publishedAt)}</div>
            <div class="transition text-[var(--text-secondary)] line-clamp-2">{formatDateToYYYYMMDD(pubDate)}</div>
        </div>
        <div>
            <div class="transition text-[var(--text-tertiary)] text-sm">{i18n(I18nKey.license)}</div>
            <a href={licenseConf.url} target="_blank" class="link text-[var(--primary)] line-clamp-2">{licenseConf.name}</a>
        </div>
    </div>
    <Icon name="fa6-brands:creative-commons" class="license-watermark transition text-[15rem] absolute pointer-events-none right-6 top-1/2 -translate-y-1/2 text-[var(--text-primary)] opacity-[0.04]"></Icon>
</div>

<style>
    .license-block {
        background: transparent;
        box-shadow: none;
    }
</style>
