---
import { Icon } from "astro-icon/components";
import { type NavBarLink } from "../../types/config";
import { url } from "../../utils/url-utils";

interface Props {
	links: NavBarLink[];
}

const links = Astro.props.links;
---
<div id="nav-menu-panel" class="nav-menu-panel float-panel float-panel-closed fixed right-4 top-[calc(var(--nav-height)+0.5rem)] min-w-[12rem] px-4 py-3 md:hidden">
    {links.map((link) => (
        <a
            href={link.external ? link.url : url(link.url)}
            class="nav-menu-link"
            target={link.external ? "_blank" : null}
        >
            <span class="nav-menu-labels">
                <span class="nav-menu-cn">{link.labelCn ?? link.name}</span>
                <span class="nav-menu-en">{link.labelEn ?? link.name}</span>
            </span>
            {!link.external && <Icon name="material-symbols:chevron-right-rounded" class="text-base opacity-40" />}
            {link.external && <Icon name="fa6-solid:arrow-up-right-from-square" class="text-xs opacity-40" />}
        </a>
    ))}
</div>

<style>
    .nav-menu-panel {
        background: var(--bg-primary, #ffffff);
        border: 1px solid var(--border-subtle, rgba(0, 0, 0, 0.1));
        border-radius: var(--search-radius, 10px);
    }

    .nav-menu-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 0;
        text-decoration: none;
        transition: color var(--duration-fast) ease;
    }

    .nav-menu-labels {
        display: flex;
        flex-direction: column;
        gap: 2px;
        line-height: 1;
    }

    .nav-menu-cn {
        font-family: var(--font-text);
        font-size: 14px;
        color: var(--text-primary);
        letter-spacing: 0.05em;
    }

    .nav-menu-en {
        font-family: var(--font-text);
        font-size: 9px;
        color: var(--text-tertiary);
        letter-spacing: 0.15em;
    }

    .nav-menu-link:hover .nav-menu-cn {
        color: var(--accent-warm, var(--text-primary));
    }
</style>
