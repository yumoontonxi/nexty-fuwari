---
import { Icon } from "astro-icon/components";
import { getGalleryUrl } from "@utils/gallery-utils";

interface Props {
	prevSlug: string | null;
	prevDescription: string | null;
	nextSlug: string | null;
	nextDescription: string | null;
}

const { prevSlug, prevDescription, nextSlug, nextDescription } = Astro.props;
---

<nav class="gallery-nav" aria-label="Gallery navigation">
	<a
		href={prevSlug ? getGalleryUrl(prevSlug) : "#"}
		class:list={["gallery-nav-link gallery-nav-link--prev", { "is-disabled": !prevSlug }]}
	>
		{prevSlug && (
			<>
				<Icon name="material-symbols:chevron-left-rounded" class="gallery-nav-icon" />
				<span class="gallery-nav-label">{prevDescription}</span>
			</>
		)}
	</a>
	<a
		href={nextSlug ? getGalleryUrl(nextSlug) : "#"}
		class:list={["gallery-nav-link gallery-nav-link--next", { "is-disabled": !nextSlug }]}
	>
		{nextSlug && (
			<>
				<span class="gallery-nav-label">{nextDescription}</span>
				<Icon name="material-symbols:chevron-right-rounded" class="gallery-nav-icon" />
			</>
		)}
	</a>
</nav>

<style>
	.gallery-nav {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	@media (min-width: 640px) {
		.gallery-nav {
			flex-direction: row;
		}
	}

	.gallery-nav-link {
		flex: 1;
		min-width: 0;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.875rem 1.125rem;
		border-radius: 12px;
		border: 1px solid var(--border-subtle);
		background: var(--bg-secondary);
		text-decoration: none;
		color: var(--text-secondary);
		transition:
			background var(--duration) var(--ease),
			color var(--duration-fast) ease,
			transform var(--duration-fast) ease;
		min-height: 3.25rem;
		overflow: hidden;
	}

	.gallery-nav-link:hover:not(.is-disabled) {
		background: var(--bg-tertiary);
		color: var(--text-primary);
		transform: translateY(-1px);
	}

	.gallery-nav-link--next {
		justify-content: flex-end;
	}

	.gallery-nav-link.is-disabled {
		display: none !important;
	}

	.gallery-nav-icon {
		flex-shrink: 0;
		font-size: 1.5rem;
		color: var(--text-primary);
	}

	.gallery-nav-label {
		flex: 1;
		min-width: 0;
		font-family: var(--font-text);
		font-size: 0.8125rem;
		letter-spacing: 0.03em;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.gallery-nav-link--prev .gallery-nav-label {
		text-align: left;
	}

	.gallery-nav-link--next .gallery-nav-label {
		text-align: right;
	}
</style>
