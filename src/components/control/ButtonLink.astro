---
interface Props {
	badge?: string;
	url?: string;
	label?: string;
}
const { badge, url, label } = Astro.props;
---
<a href={url} aria-label={label} class="sidebar-category-item">
    <span class="category-name"><slot></slot></span>
    {badge !== undefined && badge !== null && badge !== '' && (
        <span class="category-count">{badge}</span>
    )}
</a>

<style>
    .category-name {
        font-family: var(--font-text);
        font-size: 14px;
        color: inherit;
    }

    .category-count {
        font-family: var(--font-text);
        font-size: 14px;
        color: var(--text-tertiary);
        text-align: right;
        transition: color 0.2s ease;
    }

    .sidebar-category-item:hover .category-count {
        color: inherit;
        opacity: 0.75;
    }
</style>
