---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import TOC from "../components/widget/TOC.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
	hideTopNav?: boolean;
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
	hideTopNav = false,
} = Astro.props;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "0";
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<slot slot="head" name="head"></slot>
{!hideTopNav && (
    <div id="top-row" class="pointer-events-none relative z-50 w-full shrink-0">
        <div id="navbar-wrapper" class="pointer-events-auto mx-auto max-w-[var(--page-max-width)] px-[var(--page-padding)]">
            <Navbar></Navbar>
        </div>
    </div>
)}

{siteConfig.banner.enable && <div id="banner-wrapper" class={`absolute z-10 w-full overflow-hidden`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
    <ImageWrapper id="banner" alt="Banner image of the blog" class:list={["object-cover h-full opacity-0"]}
                  src={siteConfig.banner.src} position={siteConfig.banner.position}
    >
    </ImageWrapper>
</div>}

<div class="main-panel relative z-30 flex w-full flex-1 flex-col" style={siteConfig.banner.enable ? `top: ${mainPanelTop}` : undefined}>
    <slot name="hero" />

    <div class="content-area flex min-h-[calc(100vh-200px)] flex-1 flex-col">
    <div class="page-inner mx-auto flex w-full max-w-[var(--page-max-width)] flex-1 flex-col px-[var(--page-padding)]">
        <div id="main-grid" class="main-grid flex-1">
            {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                   class:list={["absolute flex h-9 items-center justify-center bg-black/60 px-3 right-4 -top-[3.25rem]", {"hover:pr-9": hasBannerLink}]}
            >
                <Icon class="mr-1 text-xl text-white/75" name="material-symbols:copyright-outline-rounded" ></Icon>
                <div class="text-xs text-white/75">{siteConfig.banner.credit.text}</div>
            </a>}

            <SideBar class="sidebar-col"></SideBar>

            <main id="swup-container" class="content-col flex min-w-0 flex-1 flex-col">
                <div id="content-wrapper" class="flex flex-1 flex-col">
                    <slot></slot>
                    <div class="footer mt-auto hidden md:block">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            <div class="footer col-span-full mt-auto block md:hidden">
                <Footer></Footer>
            </div>
        </div>

        <BackToTop></BackToTop>
    </div>
    </div>
</div>

<div class="absolute z-0 hidden w-full 2xl:block">
    <div class="relative mx-auto max-w-[var(--page-max-width)]">
        {siteConfig.toc.enable && <div id="toc-wrapper" class:list={["hidden lg:block absolute top-0 -right-[var(--toc-width)] w-[var(--toc-width)] items-center",
            {"toc-hide": siteConfig.banner.enable}]}
        >
            <div id="toc-inner-wrapper" class="fixed top-14 w-[var(--toc-width)] h-[calc(100vh_-_20rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar">
                <div id="toc" class="w-full h-full">
                    <div class="h-8 w-full"></div>
                    <TOC headings={headings}></TOC>
                    <div class="h-8 w-full"></div>
                </div>
            </div>
        </div>}

        {!siteConfig.toc.enable && <div id="toc"></div>}
    </div>
</div>
</Layout>

<style>
    .main-panel {
        background: transparent;
    }

    .content-area {
        width: 100%;
        min-height: calc(100vh - 200px);
    }

    .page-inner {
        min-height: 100%;
    }

    .main-grid {
        display: flex;
        gap: var(--content-gap);
        width: 100%;
        margin-top: 3rem;
        align-items: stretch;
    }

    .sidebar-col {
        flex-shrink: 0;
    }

    .content-col {
        flex: 1;
        min-width: 0;
    }

    #content-wrapper {
        min-height: 100%;
    }

    @media (max-width: 767px) {
        .main-grid {
            flex-direction: column;
        }
    }

    @media (min-width: 768px) and (max-width: 1024px) {
        .page-inner {
            padding-left: var(--page-padding-tablet);
            padding-right: var(--page-padding-tablet);
        }
    }
</style>
