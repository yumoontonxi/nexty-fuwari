---
import Pagination from "@components/control/Pagination.astro";
import PostPage from "@components/PostPage.astro";
import { PAGE_SIZE } from "@constants/constants";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	getMergedPosts,
	paginateUnifiedPosts,
} from "@utils/posts-merge";

export const prerender = true;

const allPosts = await getMergedPosts();
const page = paginateUnifiedPosts(allPosts, PAGE_SIZE, 1);
---

<MainGridLayout title={i18n(I18nKey.posts)} description={i18n(I18nKey.posts)}>
    <div class="page-shell flex min-h-[calc(100vh-200px)] flex-1 flex-grow flex-col" style="position:relative; overflow:hidden;">
        <div aria-hidden="true" style="
            pointer-events: none;
            position: absolute;
            top: 50%;
            right: 1.5rem;
            transform: translateY(-50%);
            display: flex;
            align-items: center;
            gap: 12px;
            opacity: 0.08;
            user-select: none;
            z-index: 0;
        ">
            <div style="width:1px; height:80px; background:var(--text-primary);"></div>
            <div style="font-size:0.7rem; font-weight:400; color:var(--text-primary); letter-spacing:0.3em; writing-mode:vertical-rl;">微 · 光</div>
        </div>
        <div class="flex-1 rounded-lg bg-[var(--bg-primary)]">
            <PostPage page={page}></PostPage>
        </div>

        <Pagination class="mx-auto mt-8" page={page} basePath="/posts/"></Pagination>
    </div>
</MainGridLayout>
