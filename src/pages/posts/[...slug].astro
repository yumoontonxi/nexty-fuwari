---
import path from "node:path";
import CommentsStub from "@components/CommentsStub.astro";
import ArticleNav from "@components/ArticleNav.astro";
import License from "@components/misc/License.astro";
import SharePoster from "@components/misc/SharePoster.astro";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import SingleColumnLayout from "@layouts/SingleColumnLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { getDir } from "@utils/url-utils";
import { getMergedPostNavigationByLocalSlug } from "@utils/posts-merge";
import { licenseConfig } from "src/config";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";
import { profileConfig, siteConfig } from "../../config";
import { getEntry, type CollectionEntry } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
	const posts = await getSortedPosts();
	return posts.map((entry) => ({
		params: { slug: String(entry.slug).replace(/^\/+|\/+$/g, "") },
		props: { entry },
	}));
}

const rawSlug = Astro.params.slug;
const slugParam = Array.isArray(rawSlug)
	? rawSlug.join("/").replace(/^\/+|\/+$/g, "")
	: (rawSlug ?? "").replace(/^\/+|\/+$/g, "");
let entry: CollectionEntry<"posts"> | undefined = Astro.props.entry;

if (!entry && slugParam) {
	entry = (await getEntry("posts", slugParam)) ?? undefined;
}

if (!entry) {
	return Astro.redirect("/404/");
}

const { Content } = await entry.render();
const { remarkPluginFrontmatter } = await entry.render();
const navigation = await getMergedPostNavigationByLocalSlug(entry.slug);

const pageOrigin = Astro.site ?? Astro.url;
const posterCoverUrl = entry.data.image
	? new URL(
			entry.data.image.startsWith("/") ? entry.data.image : `/${entry.data.image}`,
			pageOrigin,
		).href
	: "";
const posterPageUrl = Astro.url.href;

const categoryLabel = (entry.data.category || i18n(I18nKey.uncategorized)).toUpperCase();
const dateLabel = formatDateToYYYYMMDD(entry.data.published);
const readTimeLabel = `${remarkPluginFrontmatter.minutes} ${i18n(remarkPluginFrontmatter.minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount)}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.data.title,
  description: entry.data.description || entry.data.title,
  keywords: entry.data.tags,
  author: {
    "@type": "Person",
    name: profileConfig.name,
    url: Astro.site,
  },
  datePublished: formatDateToYYYYMMDD(entry.data.published),
  inLanguage: entry.data.lang
    ? entry.data.lang.replace("_", "-")
    : siteConfig.lang.replace("_", "-"),
};
---
<SingleColumnLayout title={entry.data.title} description={entry.data.description} lang={entry.data.lang}>
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    <article class="article-page onload-animation">
        <header class="article-header">
            <h1 class="article-title" data-pagefind-body data-pagefind-weight="10" data-pagefind-meta="title">
                {entry.data.title}
            </h1>
            <p class="article-meta">
                <span>{dateLabel}</span>
                <span class="article-meta-sep">·</span>
                <span>{categoryLabel}</span>
                <span class="article-meta-sep">·</span>
                <span>{readTimeLabel}</span>
            </p>
        </header>

        {entry.data.image && (
            <ImageWrapper
                id="post-cover"
                src={entry.data.image}
                basePath={path.join("content/posts/", getDir(entry.id))}
                class="article-cover onload-animation"
            />
        )}

        <Markdown class="article-content markdown-content onload-animation">
            <Content />
        </Markdown>

        {licenseConfig.enable && (
            <License
                title={entry.data.title}
                slug={entry.slug}
                pubDate={entry.data.published}
                class="article-license onload-animation"
            />
        )}
    </article>

    <ArticleNav navigation={navigation} />

    <SharePoster
        posterId={`poster-${entry.slug}`}
        title={entry.data.title}
        date={dateLabel}
        author={profileConfig.name}
        excerpt={entry.data.description || entry.data.title}
        coverUrl={posterCoverUrl}
        pageUrl={posterPageUrl}
        category={categoryLabel}
    />

    <CommentsStub />
</SingleColumnLayout>

<style>
    .article-page {
        max-width: var(--article-max-width);
        margin: 0 auto;
        padding: 3rem 0 2rem;
        background: var(--bg-primary);
    }

    .article-meta {
        font-family: var(--font-text);
        font-size: 11px;
        font-weight: 400;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-tertiary);
        margin: 16px 0 2.5rem;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.35rem;
    }

    .article-meta-sep {
        color: var(--text-tertiary);
    }

    .article-title {
        font-family: var(--font-display);
        font-size: var(--font-size-title);
        font-weight: 300;
        letter-spacing: 0.02em;
        color: var(--text-primary);
        line-height: 1.25;
        margin: 0;
    }

    .article-cover {
        margin-bottom: 2.5rem;
        border-radius: 12px !important;
        overflow: hidden;
    }

    .article-cover :global(img) {
        width: 100%;
        border-radius: 12px;
    }

    .article-content {
        margin-bottom: 2rem;
    }

    :global(.article-license) {
        background: transparent !important;
        box-shadow: none !important;
        border-radius: 0 !important;
        border-left: 2px solid var(--accent-warm);
        color: var(--text-secondary);
    }

    :global(.article-license .license-title) {
        color: var(--text-primary);
    }
</style>
